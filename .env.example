# ── Client-side (Vite) ────────────────────────────────────────────────────────
# Convex — deployment URL written to .env.local by `npx convex dev`
VITE_CONVEX_URL=

# Clerk — publishable key from the Clerk Dashboard → API Keys (starts with pk_test_ or pk_live_)
VITE_CLERK_PUBLISHABLE_KEY=

# ── Convex server-side env vars (set via `npx convex env set <KEY> <VALUE>`) ──
# Clerk Frontend API URL — Clerk Dashboard → API Keys → "Frontend API" value
# Required by convex/auth.config.ts so ctx.auth works in server functions.
# Also create a JWT Template named "convex" in the Clerk Dashboard.
CLERK_ISSUER_URL=
